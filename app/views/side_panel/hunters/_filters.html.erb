<div class="p-4 w-full mb-4 bg-white rounded-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700">
  <div class="flex flex-col space-y-4">
    <%= form_with scope: :hunter_location, url: side_panel_hunters_path, method: :get, class: "w-full" do |form| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= form.label :from, "Период с", class: "block text-sm font-medium text-gray-700 mb-2 dark:text-zinc-200" %>
          <%= form.date_field :from,
                value: params.dig(:hunter_location, :from).presence,
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 dark:bg-zinc-200 dark:border-gray-500 dark:text-black dark:focus:ring-indigo-400" %>
        </div>

        <div>
          <%= form.label :to, "Период по", class: "block text-sm font-medium text-gray-700 mb-2 dark:text-zinc-200" %>
          <%= form.date_field :to,
                value: params.dig(:hunter_location, :to).presence,
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 dark:bg-zinc-200 dark:border-gray-500 dark:text-black dark:focus:ring-indigo-400" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div>
          <%= form.label :dog, "Собака", class: "block text-sm font-medium text-gray-700 mb-2 dark:text-zinc-200" %>
          <%= form.select :dog,
                options_for_select(HunterLocationSearch::DOG_OPTIONS, params.dig(:hunter_location, :dog)),
                {include_blank: true},
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 dark:bg-zinc-200 dark:border-gray-500 dark:text-black dark:focus:ring-indigo-400" %>
        </div>

        <div>
          <%= form.label :license, "Лицензия", class: "block text-sm font-medium text-gray-700 mb-2 dark:text-zinc-200" %>
          <%= form.select :license,
                options_for_select(HunterLocationSearch::LICENSE_OPTIONS, params.dig(:hunter_location, :license)),
                {include_blank: true},
                class: "w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 dark:bg-zinc-200 dark:border-gray-500 dark:text-black dark:focus:ring-indigo-400" %>
        </div>
      </div>

      <div class="flex space-x-3 pt-2">
        <%= form.submit "Фильтровать",
              class: "cursor-pointer px-4 py-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 text-sm font-medium dark:text-black" %>

        <%= form.submit "Сбросить", type: :reset,
              class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition duration-200 text-sm font-medium cursor-pointer dark:text-black" %>
      </div>
    <% end %>
  </div>
</div>
