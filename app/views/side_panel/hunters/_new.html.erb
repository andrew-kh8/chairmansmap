<%= turbo_frame_tag "side_panel" do %>
    <div class="card p-8 flex flex-col w-full">
        <%= form_for :hunter_location, url: side_panel_hunters_path, html: {class: "h-full flex flex-col"} do |form| %>
            <div class="flex-auto space-y-6">
                <div>
                    <%= form.label :location, "Локация", class: "block text-sm font-medium text-default-color mb-2" %>
                    <%= form.text_field :location,
                          class: "text-input w-full px-4 py-3 transition duration-200" %>
                </div>

                <div>
                    <%= form.label :date, "Дата и время", class: "block text-sm font-medium text-default-color mb-2" %>
                    <%= form.datetime_field :date,
                          value: DateTime.now.strftime("%Y-%m-%dT%H:%M"),
                          class: "text-input w-full px-4 py-3 transition duration-200" %>
                </div>

                <div>
                    <%= form.check_box :license, class: "w-4 h-4 text-color-primary rounded border-gray-300 focus:ring-color-primary" %>
                    <%= form.label :license, "Лицензия", class: "text-sm text-default-color mb-4" %>
                </div>

                <div>
                    <%= form.check_box :dog, class: "w-4 h-4 text-color-primary rounded border-gray-300 focus:ring-color-primary" %>
                    <%= form.label :dog, "Собака", class: "text-sm text-default-color" %>
                </div>

                <div>
                    <%= form.label :description, "Описание", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
                    <%= form.text_area :description,
                          rows: 4,
                          class: "text-input w-full px-4 py-3 transition duration-200 resize-none" %>
                </div>
            </div>

            <div class="flex space-x-4 pt-6 mt-6 border-t border-gray-200 dark:border-gray-700">
                <%= form.submit "Сохранить",
                      class: "flex-1 px-6 py-3 btn-primary rounded-lg transition duration-200 font-medium" %>
                <%= link_to "Отмена", side_panel_hunters_path,
                      class: "flex-1 px-6 py-3 text-center border border-gray-300 text-default-color rounded-lg hover:bg-white/10 transition duration-200 font-medium" %>
            </div>
        <% end %>
    </div>
<% end %>
