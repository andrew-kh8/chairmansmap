<%= turbo_frame_tag "side_panel" do %>
<script>
    var newMarker;

    map.on('click', (event) => {
        $("#hunter_location_location").val([event.latlng.lat, event.latlng.lng].join(" "));

        if (typeof newMarker == 'undefined') {
            newMarker = new L.marker(event.latlng).addTo(map);
            newMarker.getElement().style.filter = 'hue-rotate(120deg)';
        } else {
            newMarker.setLatLng(event.latlng);
        };
    });
</script>

<div class="rounded-xl p-8 flex flex-col w-full border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700">
    <%= form_for :hunter_location, url: side_panel_hunters_path, html: {class: "h-full flex flex-col"} do |form| %>
        <div class="flex-auto space-y-6">
            <!-- Локация -->
            <div>
                <%= form.label :location, "Локация", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
                <%= form.text_field :location,
                      class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-100 dark:focus:ring-indigo-400" %>
            </div>

            <!-- Дата и время -->
            <div>
                <%= form.label :date, "Дата и время", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
                <%= form.datetime_field :date,
                      value: DateTime.now.strftime("%Y-%m-%dT%H:%M"),
                      class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 dark:bg-gray-700 dark:border-gray-600 dark:text-gray-100 dark:focus:ring-indigo-400" %>
            </div>

            <!-- Чекбоксы -->
            <div class="space-y-4">
                <label class="flex items-center space-x-3">
                    <%= form.check_box :license,
                          class: "w-4 h-4 text-indigo-500 rounded border-gray-300 focus:ring-indigo-500 dark:bg-gray-700 dark:border-gray-600" %>
                    <span class="text-sm text-gray-700 dark:text-gray-300">Лицензия</span>
                </label>

                <label class="flex items-center space-x-3">
                    <%= form.check_box :dog,
                          class: "w-4 h-4 text-indigo-500 rounded border-gray-300 focus:ring-indigo-500 dark:bg-gray-700 dark:border-gray-600" %>
                    <span class="text-sm text-gray-700 dark:text-gray-300">С собакой</span>
                </label>
            </div>

            <!-- Описание -->
            <div>
                <%= form.label :description, "Описание", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
                <%= form.text_area :description,
                      rows: 4,
                      class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 resize-none dark:bg-gray-700 dark:border-gray-600 dark:text-gray-100 dark:focus:ring-indigo-400" %>
            </div>
        </div>

        <!-- Кнопки -->
        <div class="flex space-x-4 pt-6 mt-6 border-t border-gray-200 dark:border-gray-700">
            <%= form.submit "Сохранить",
                  class: "flex-1 px-6 py-3 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 font-medium dark:bg-indigo-600 dark:hover:bg-indigo-700 dark:text-black" %>
            <%= link_to "Отмена", side_panel_hunters_path,
                  class: "flex-1 px-6 py-3 text-center border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition duration-200 font-medium dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700" %>
        </div>
    <% end %>
</div>
<% end %>
