<li class="card2 p-2 my-1 rounded-xl">
    <div class="flex items-center space-x-4">
        <div class="flex-1 min-w-0">
            <p class="text-base font-medium truncate text-default-color">
                <%= hunter.description %>
            </p>
            <p class="text-sm text-default-color truncate">
                <%= [hunter.dog ? "с собакой" : nil, hunter.license ? "с оружием" : nil].compact.join(", ") %>
            </p>
        </div>

        <div class="inline-flex items-center text-base font-semibold text-default-color">
            <%= hunter.date.strftime("%d.%m.%Y %H:%M") %>
        </div>

        <%= button_to side_panel_hunter_path(hunter), method: :delete do %>
            <svg xmlns="http://www.w3.org/2000/svg" height="50px" viewBox="0 0 56 56">
                <path fill="darkred" fill-rule="evenodd" d="M36 26v10.997c0 1.659-1.337 3.003-3.009 3.003h-9.981c-1.662 0-3.009-1.342-3.009-3.003v-10.997h16zm-2 0v10.998c0 .554-.456 1.002-1.002 1.002h-9.995c-.554 0-1.002-.456-1.002-1.002v-10.998h12zm-9-5c0-.552.451-1 .991-1h4.018c.547 0 .991.444.991 1 0 .552-.451 1-.991 1h-4.018c-.547 0-.991-.444-.991-1zm0 6.997c0-.551.444-.997 1-.997.552 0 1 .453 1 .997v6.006c0 .551-.444.997-1 .997-.552 0-1-.453-1-.997v-6.006zm4 0c0-.551.444-.997 1-.997.552 0 1 .453 1 .997v6.006c0 .551-.444.997-1 .997-.552 0-1-.453-1-.997v-6.006zm-6-5.997h-4.008c-.536 0-.992.448-.992 1 0 .556.444 1 .992 1h18.016c.536 0 .992-.448.992-1 0-.556-.444-1-.992-1h-4.008v-1c0-1.653-1.343-3-3-3h-3.999c-1.652 0-3 1.343-3 3v1z" />
            </svg>
        <% end %>
    </div>
</li>
