<div class="px-4 py-4 w-full mb-6 bg-white rounded-xl border border-gray-200 p-6">
    <div class="grid grid-cols-2 gap-4">
        <div>
            <span class="block text-sm font-medium text-gray-700 mb-2">Статус продажи</span>
            <select id="filter_sale_status" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                <%= options_for_select(["не важно", "продается", "не продается"]) %>
            </select>
        </div>

        <div>
            <span class="block text-sm font-medium text-gray-700 mb-2">Тип владения</span>
            <select id="filter_owner_type" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                <%= options_for_select(["не важно", "личная собственность", "государственная собственность"]) %>
            </select>
        </div>

        <div id="filters" class="px-4 py-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 text-sm font-medium cursor-pointer">Фильтровать</div>
        <div id="reset_filters" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition duration-200 text-sm font-medium cursor-pointer">Сбросить</div>
    </div>
</div>
