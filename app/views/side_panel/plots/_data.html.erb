<%= turbo_frame_tag "side_panel_plot_data" do %>
    <div class="border-b border-gray-200 pb-4 mb-4 dark:border-gray-700">
        <%= link_to plot_path(plot), class: "flex justify-between", data: {turbo: false} do %>
            <div class="text-xl text-gray-900 dark:text-black">
                    Данные участка № <b id="plot_number" class="font-semibold text-indigo-600 dark:text-black"><%= plot.number %></b>
            </div>
            <div>→</div>
        <% end %>
    </div>

    <div id="show_data_form" class="flex flex-col h-full">
        <div class="flex-auto space-y-4">

            <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Владелец участка</h3>
                <div class="space-y-1 text-gray-700 dark:text-black">
                    <div><span class="font-medium dark:text-inherit">Тип владения:</span> <span class="text-indigo-600 dark:text-black"><%= plot.owner_type %></span></div>
                    <div><span class="font-medium dark:text-inherit">ФИО:</span> <span id="owner_fio" class="text-indigo-600 dark:text-black"><%= plot.person.full_name %></span></div>
                    <div><span class="font-medium dark:text-inherit">Тел:</span> <span id="owner_tel" class="text-indigo-600 dark:text-black"><%= plot.person.tel %></span></div>
                    <div><span class="font-medium dark:text-inherit">Адрес:</span> <span id="owner_adr" class="text-indigo-600 dark:text-black"><%= plot.person.address %></span></div>
                </div>
            </div>

            <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Данные участка</h3>
                <div class="space-y-1 text-gray-700 dark:text-black">
                    <div><span class="font-medium dark:text-inherit">Кадастровый №:</span> <span class="text-indigo-600 dark:text-black"><%= plot.cadastral_number %></span></div>
                    <div><span class="font-medium dark:text-inherit">Площадь:</span> <span class="text-indigo-600 dark:text-black"><%= plot.area %></span></div>
                    <div><span class="font-medium dark:text-inherit">Периметр:</span> <span class="text-indigo-600 dark:text-black"><%= plot.perimeter %></span></div>
                    <div><span class="font-medium dark:text-inherit">Статус продажи:</span> <span class="text-indigo-600 dark:text-black"><%= plot.sale_status %></span></div>
                    <div>
                        <div class="font-medium mb-2 dark:text-black">Дополнительная информация:</div>
                        <div class="text-gray-600 bg-gray-50 p-3 rounded-lg dark:bg-zinc-200">
                            <%= plot.description %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%= link_to "Обновить данные участка", edit_side_panel_plot_path(plot), class: "mt-6 px-6 py-3 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 font-medium disabled:bg-gray-400 disabled:text-gray-200 disabled:cursor-not-allowed"%>
    </div>
<% end %>
