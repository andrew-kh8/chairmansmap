<%= form_with url: people_path, method: :get, class: "flex-1" do |form| %>
<div class="flex flex-col sm:flex-row gap-4 flex-wrap items-center">
    <div class="flex flex-col gap-4">
    <!-- Фильтр по статусу -->
    <div class="flex">
        <div class="text-sm font-medium text-gray-700 mr-2 dark:text-black">Статус</div>
        <div class="flex items-center space-x-6">
            <%= label_tag :active_, class: "flex items-center space-x-2 cursor-pointer dark:text-black" do %>
                <%= radio_button_tag :active, "", params[:active] == "" || params[:active].blank?, class: "text-indigo-500 focus:ring-indigo-500" %>
                <span class="text-sm text-gray-700 dark:text-black">Все</span>
            <% end %>

            <%= label_tag :active_true, class: "flex items-center space-x-2 cursor-pointer dark:text-black" do %>
                <%= radio_button_tag :active, true, params[:active] == "true", class: "text-indigo-500 focus:ring-indigo-500" %>
                <span class="text-sm text-gray-700 dark:text-black">Активные</span>
            <% end %>

            <%= label_tag :active_false, class: "flex items-center space-x-2 cursor-pointer dark:text-black" do %>
                <%= radio_button_tag :active, false, params[:active] == "false", class: "text-indigo-500 focus:ring-indigo-500" %>
                <span class="text-sm text-gray-700 dark:text-black">Архивные</span>
            <% end %>
        </div>
    </div>

    <!-- Фильтр по участкам -->
    <div class="flex">
        <div class="text-sm font-medium text-gray-700 mr-2 dark:text-black">Участки</div>
        <div class="flex items-center space-x-6">
            <%= label_tag :plot_presence_, class: "flex items-center space-x-2 cursor-pointer dark:text-black" do %>
                <%= radio_button_tag :plot_presence, "", params[:plot_presence] == "" || params[:plot_presence].blank?, class: "text-indigo-500 focus:ring-indigo-500" %>
                <span class="text-sm text-gray-700 dark:text-black">Все</span>
            <% end %>

            <%= label_tag :plot_presence_true, class: "flex items-center space-x-2 cursor-pointer dark:text-black" do %>
                <%= radio_button_tag :plot_presence, true, params[:plot_presence] == "true", class: "text-indigo-500 focus:ring-indigo-500" %>
                <span class="text-sm text-gray-700 dark:text-black">С участками</span>
            <% end %>

            <%= label_tag :plot_presence_false, class: "flex items-center space-x-2 cursor-pointer dark:text-black" do %>
                <%= radio_button_tag :plot_presence, false, params[:plot_presence] == "false", class: "text-indigo-500 focus:ring-indigo-500" %>
                <span class="text-sm text-gray-700 dark:text-black">Без участка</span>
            <% end %>
        </div>
    </div>
    </div>

    <!-- Поле поиска -->
    <div class="flex-1 min-w-[200px] relative">
        <%= text_field_tag :full_name,
              params[:full_name],
              autocomplete: nil,
              placeholder: "ФИО...",
              class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 text-sm dark:bg-zinc-200" %>

        <% if params[:full_name].present? %>
            <%= button_tag type: "button", onclick: "this.previousElementSibling.value=''; this.previousElementSibling.focus()", class: "absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-600 transition duration-150 dark:text-black" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            <% end %>
        <% end %>
    </div>

    <!-- Кнопка поиска -->
    <%= submit_tag "Поиск",
          name: nil,
          class: "cursor-pointer px-4 py-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 text-sm font-medium whitespace-nowrap dark:text-black" %>
</div>
<% end %>
