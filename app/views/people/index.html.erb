<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mx-20 mb-6 dark:bg-zinc-500 dark:border-gray-700">
    <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm dark:bg-zinc-500 dark:border-gray-700">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <!-- Фильтры -->
            <%= render partial: "form" %>

            <!-- Кнопка создания -->
            <%= link_to new_plot_path, class: "px-6 py-3 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 font-medium flex items-center gap-2 whitespace-nowrap dark:text-black" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Новый участок
            <% end %>
        </div>
    </div>
</div>

<!--таблица-->
<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mx-20 dark:border-gray-700">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-zinc-500">
                <tr>
                    <%= render partial: "headers", collection: table_headers, as: :header_data %>
                </tr>
            </thead>

            <tbody class="bg-white divide-y divide-gray-200 dark:bg-zinc-500 dark:divide-gray-700">
                <%= render partial: "person_row", collection: @people, as: :person %>
            </tbody>
        </table>
    </div>
</div>

<!-- Пагинация -->
<div class="flex-none flex justify-center items-center">
    <%== @pagy.series_nav %>
</div>
