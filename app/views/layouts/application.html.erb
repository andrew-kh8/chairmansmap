<!DOCTYPE html>
<html>
  <head>
    <title>Chairmansmap</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <!-- Leaflet CSS and JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css">
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <%= favicon_link_tag "favicon.png", skip_pipeline: true %>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-screen max-h-screen flex flex-col <%= (cookies[:dark_theme] == "1") ? "dark" : "" %> dark:bg-gray-900">

    <%= turbo_frame_tag :flashes, class: "fixed top-4 right-4 z-50 w-80 space-y-3" do %>
      <%= render "application/flashes" %>
    <% end %>

    <header class="w-full bg-white border-b border-gray-200 dark:bg-gray-900 dark:border-gray-700">

      <div class="container mx-auto px-6 py-4">
        <nav class='flex items-center justify-between'>
          <div></div>
          <div class="flex items-center space-x-8">
            <%= link_to "Карта", root_path, class: "text-gray-600 hover:text-btn-green font-medium transition duration-200 dark:text-zinc-400 dark:hover:text-btn-green" %>
            <%= link_to "Участники", people_path, class: "text-gray-600 hover:text-btn-green font-medium transition duration-200 dark:text-zinc-400 dark:hover:text-btn-green" %>
            <%= link_to "Участки", plots_path, class: "text-gray-600 hover:text-btn-green font-medium transition duration-200 dark:text-zinc-400 dark:hover:text-btn-green" %>
            <%= link_to "Организации", villages_path, class: "text-gray-600 hover:text-btn-green font-medium transition duration-200 dark:text-zinc-400 dark:hover:text-btn-green" %>
          </div>

          <div>
            <!-- Кнопка темы -->
            <%= button_tag type: "button", data: {controller: "theme", action: "click->theme#toggle", theme_target: "button"}, class: "p-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition duration-200" do %>
              <!-- Солнце (светлая тема) -->
              <svg data-theme-target="sunIcon" class="w-5 h-5 <%= "hidden" if cookies[:dark_theme] == "1" %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              <!-- Луна (темная тема) -->
              <svg data-theme-target="moonIcon" class="w-5 h-5 <%= "hidden" unless cookies[:dark_theme] == "1" %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
              </svg>
            <% end %>
          </div>
        </nav>
      </div>
    </header>

    <main class="w-full flex-auto dark:bg-gray-900">
      <%= yield %>
    </main>

    <footer class="pt-1 bg-gray-300 text-gray-800 dark:bg-gray-900 dark:text-zinc-400">
      <div class="text-sm text-center">
        <p>
          Copyright © 2023 - Andrew
        </p>
      </div>
    </footer>
  </body>
</html>
