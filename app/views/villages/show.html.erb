<div class="flex h-full min-h-0" data-controller="village" data-village-id-value="<%= village.id %>">
    <div class="w-3/5 h-full min-h-0 p-4">
        <div class="w-full h-full rounded-xl" data-village-target="map"></div>
    </div>

    <div class="w-2/5 flex flex-col h-full min-h-0 p-4 space-y-6">
        <section class="card p-6">
            <h2 class="text-xl font-semibold text-default-color mb-4">Основная информация</h2>
            <div class="space-y-3">
                <div class="flex justify-between">
                    <span class="text-default-color">Название</span>
                    <span class="font-medium text-default-color"><%= village.name %></span>
                </div>
                <div class="flex justify-between">
                    <span class="text-default-color">Площадь:</span>
                    <span class="font-medium text-default-color"><%= village.geom.area.round(2) %> м</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-default-color">Кадастровый номер:</span>
                    <span class="font-medium text-default-color"><%= village.cadastral_number %></span>
                </div>
            </div>
        </section>

        <section class="card space-y-4 p-6 pr-3">
            <% if village.agromonitoring_integration? %>
                <h2 class="text-xl font-semibold text-default-color mb-4">Агромониторинг</h2>
                <%= render "agromonitoring_tiles", village: %>

                <%= form_with url: add_tiles_village_agromonitoring_path(village) do |form| %>
                    <%= form.date_field :from, value: 1.weeks.ago.to_date, class: "text-input w-1/3 px-3 py-2 text-sm transition duration-200" %>
                    <%= form.date_field :to, value: Date.current, class: "text-input w-1/3 px-3 py-2 text-sm transition duration-200" %>
                    <%= form.submit "Добавить снимки", class: "btn-primary py-2 px-4 rounded-lg" %>
                <% end %>

                <%= button_to "Удалить интеграцию",
                      village_agromonitoring_path(village),
                      class: "btn-alarm py-2 px-4 rounded-lg",
                      method: :delete,
                      form: {data: {turbo_confirm: "Нажмите 'OK' чтобы удалить интеграцию"}} %>
            <% else %>
                <p class="text-default-color">Агромониторинг не интегрирован</p>
                <%= button_to "Интегрировать агромониторинг", village_agromonitoring_path(village), class: "btn-primary py-2 px-4 rounded-lg" %>
            <% end %>
        </section>
    </div>
</div>
