<div class="relative flex max-h-full flex-col justify-center overflow-hidden py-6 h-full">
    <div class="mx-auto max-w-screen-xl px-4 w-full mb-6">
        <div class="bg-gray-100 rounded-xl border border-gray-200 p-6 mb-4 shadow-sm dark:bg-gray-800 dark:border-gray-700">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <%# render "filters" %>

                <!-- Кнопка создания -->
                <%= link_to new_village_path, class: "px-6 py-3 bg-btn-green text-white rounded-lg hover:bg-indigo-600 transition duration-200 font-medium flex items-center gap-2 dark:text-black" do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    Новая деревня
                <% end %>
            </div>
        </div>
    </div>

    <!-- Сетка участков -->
    <div class="mx-auto max-w-screen-xl px-4 w-full flex-grow">
        <div class="grid w-full sm:grid-cols-2 xl:grid-cols-4 gap-6">
            <%= render partial: "village_card", collection: villages, as: :village %>
        </div>
    </div>

    <!-- Пагинация -->
    <% if pagy.last > 1 %>
        <div class="flex-none flex justify-center items-center mt-8">
            <%== pagy.series_nav %>
        </div>
    <% end %>
</div>
