<div class="max-h-full bg-white py-8 dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-6">

        <%= form_with model: village, class: "bg-white rounded-xl border border-gray-200 p-8 dark:bg-zinc-600 dark:border-gray-700", data: {controller: "cadastral-number"} do |f| %>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="space-y-6">
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <%= f.label :cadastral_number, "Кадастровый номер", class: "block text-sm font-medium text-gray-700 dark:text-black" %>
                        <%= button_tag "Проверить", type: "button", data: {action: "click->cadastral-number#check", check_type: "villages"}, class: "px-4 py-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 text-sm font-medium dark:text-black" %>
                    </div>
                    <%= f.text_field :cadastral_number,
                          data: {cadastral_number_target: "input"},
                          class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 dark:bg-zinc-200",
                          placeholder: "77:01:0001001" %>
                    <div data-cadastral-number-target="result"></div>
                </div>

                <div>
                    <%= f.label :name, "Название", class: "block text-sm font-medium text-gray-700 mb-2 dark:text-black" %>
                    <%= f.text_field :name,
                          class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition duration-200 dark:bg-zinc-200",
                          placeholder: "Название деревни" %>
                </div>
            </div>

            <div class="space-y-6">
                <!-- Фото -->
                <div class="h-64">
                    <%= f.label :photos, "Фотографии участка", class: "block text-sm font-medium text-gray-700 mb-2 dark:text-black" %>
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center h-48 flex flex-col justify-center dark:border-gray-700">
                        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <p class="mt-2 text-sm text-gray-600">Перетащите фото или кликните для загрузки</p>
                        <%= f.file_field :photos, multiple: true, class: "hidden" %>
                        <%= button_tag "Выбрать файлы", type: "button", class: "mt-3 px-4 py-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 text-sm font-medium dark:text-black" %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Кнопки действий -->
        <div class="flex justify-end space-x-4 pt-4 border-t border-gray-200">
            <%= link_to "Отмена", villages_path,
                  class: "px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition duration-200 font-medium dark:text-black" %>
            <%= f.submit "Создать деревню",
                  disabled: true,
                  data: {cadastral_number_target: "submit"},
                  class: "px-6 py-3 rounded-lg transition duration-200 font-medium dark:text-black" %>
        </div>
        <% end %>
    </div>
</div>
