<div class="card relative flex flex-col overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 max-w-sm">

    <%= link_to "", plot_path(plot), class: "z-20 absolute h-full w-full top-0 left-0" %>

    <div class="py-4 px-3">
        <div class="flex justify-between">
            <h3 class="text-xs mb-2 font-medium text-gray-100">№ <%= plot.number %></h3>
            <% if plot.person %>
                <%= link_to person_path(plot.person), class: "relative z-30" do %>
                    <h3 class="text-xs mb-2 font-medium text-gray-100"><%= plot.person.short_name %></h3>
                <% end %>
            <% else %>
                <h3 class="text-xs mb-2 font-medium text-gray-100">Не указано</h3>
            <% end %>
        </div>

        <div class="flex justify-between items-center">
            <p class="text-xs text-default-color">
                Кадастровый № <%= plot.cadastral_number %>
            </p>
        </div>
    </div>
</div>
