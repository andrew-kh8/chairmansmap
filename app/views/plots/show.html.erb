<meta name="openweather-api-key" content="<%= ENV['OPEN_WEATHER_API_KEY'] %>">

<div class="flex h-4/5">
    <!-- Левая часть - карта -->
    <div class="w-3/5 h-3/5">
        <div
             class="w-full h-full"
             data-controller="plot"
             data-plot-target="map"
             data-plot-id-value="<%= plot.id %>">
        </div>
    </div>

    <!-- Правая часть - информация -->
    <div class="w-2/5 h-4/5 overflow-y-auto bg-white dark:bg-gray-900">
        <div class="p-6 space-y-6">
            <!-- Основная информация -->
            <section class="bg-white rounded-lg border border-gray-200 p-6 dark:bg-zinc-500 dark:border-gray-700">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Основная информация</h2>
                <div class="space-y-3">
                    <div class="flex justify-between">
                        <span class="text-gray-600 dark:text-black">Номер участка:</span>
                        <span class="font-medium"><%= plot.number %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-600 dark:text-black">Площадь:</span>
                        <span class="font-medium"><%= plot.area %> м</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-600 dark:text-black">Кадастровый номер:</span>
                        <span class="font-medium"><%= plot.cadastral_number %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-600 dark:text-black">Статус продажи:</span>
                        <span class="px-2 py-1 bg-green-100 text-green-800 text-xs rounded-full"><%= plot.sale_status %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-600 dark:text-black">Тип владения:</span>
                        <span class="px-2 py-1 bg-green-100 text-green-800 text-xs rounded-full"><%= plot.owner_type %></span>
                    </div>
                </div>
            </section>

            <!-- Владельцы -->
            <section class="bg-white rounded-lg border border-gray-200 p-6 dark:bg-zinc-500 dark:border-gray-700">
                <div class="space-y-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-indigo-100 rounded-full flex items-center justify-center dark:bg-gray-100">
                            <span class="text-indigo-600 font-medium">:)</span>
                        </div>
                        <div>
                          <%= link_to(person.full_name, person_path(person), class: "font-medium") %>
                            <p class="text-sm text-gray-500 dark:text-black"><%= person.tel %></p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Погода -->
            <section class="bg-white rounded-lg border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
                <% if weather.present? %>
                  <%= render "plots/show/weather", weather: weather %>
                <% else %>
                  <%= render "plots/show/no_content" %>
                <% end %>
            </section>

            <!-- Фотографии -->
            <section class="bg-white rounded-lg border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
                <% if plot.photos.any? %>
                  <%= render "plots/show/photos", photos: plot.photos %>
                <% else %>
                  <%= render "plots/show/no_content" %>
                <% end %>
            </section>

            <!-- История изменений -->
            <section class="bg-white rounded-lg border border-gray-200 p-6 dark:bg-zinc-500 dark:border-gray-700">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">История изменений</h2>
                <div class="space-y-4">
                    <div class="flex justify-between items-start">
                        <div>
                            <p class="font-medium dark:text-black">Изменен статус участка</p>
                            <p class="text-sm text-gray-500 dark:text-black">Иван Иванов</p>
                        </div>
                        <span class="text-sm text-gray-400 dark:text-black">2 часа назад</span>
                    </div>
                    <div class="flex justify-between items-start">
                        <div>
                            <p class="font-medium dark:text-black">Добавлен новый владелец</p>
                            <p class="text-sm text-gray-500 dark:text-black">Петр Петров</p>
                        </div>
                        <span class="text-sm text-gray-400 dark:text-black">1 день назад</span>
                    </div>
                </div>
            </section>

            <!-- Действия -->
            <section class="bg-white rounded-lg border border-gray-200 p-6 dark:bg-zinc-500 dark:border-gray-700">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Действия</h2>
                <div class="space-y-3">
                    <%= button_tag "Редактировать информацию", type: "button", class: "w-full bg-btn-green text-white py-3 px-4 rounded-lg hover:bg-indigo-600 transition duration-200 font-medium dark:text-black dark:border-gray-700" %>
                    <%= button_tag "Скачать документы", type: "button", class: "w-full border border-indigo-500 text-indigo-500 py-3 px-4 rounded-lg hover:bg-indigo-50 transition duration-200 font-medium dark:text-black dark:border-gray-700 dark:hover:bg-zinc-700" %>
                    <%= button_to "Удалить участок и все записи о нем",
                          plot_path(plot),
                          method: :delete,
                          form: {data: {turbo_confirm: "Нажмите 'OK' чтобы удалить участок"}},
                          class: "w-full border border-red-300 text-red-700 py-3 px-4 rounded-lg hover:bg-red-50 transition duration-200 font-medium dark:bg-red-950 dark:text-red-600 dark:border-gray-700 dark:hover:bg-zinc-700" %>
                </div>
            </section>
        </div>
    </div>
</div>
