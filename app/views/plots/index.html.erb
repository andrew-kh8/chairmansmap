<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<div class="relative flex max-h-full flex-col justify-center overflow-hidden py-6 h-full">
    <!-- Фильтры и кнопка создания -->
    <div class="mx-auto max-w-screen-xl px-4 w-full mb-6">
        <div class="bg-gray-100 rounded-xl border border-gray-200 p-6 mb-4 shadow-sm dark:bg-zinc-500 dark:border-gray-700">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <!-- Фильтры -->
                <%= form_with url: plots_path, method: :get do |form| %>
                <div class="flex flex-col sm:flex-row gap-4 flex-wrap">
                    <!-- Площадь -->
                    <div class="flex items-center gap-2 text-gray-600 dark:text-black">
                        <span class="text-sm text-inherit">Площадь:</span>
                        <%= form.number_field :area_min, placeholder: "От", value: params[:area_min], class: "w-20 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 dark:bg-zinc-200" %>
                        <span class="text-inherit">-</span>
                        <%= form.number_field :area_max, placeholder: "До", value: params[:area_max], class: "w-20 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 dark:bg-zinc-200" %>
                        <span class="text-sm text-inherit">сот.</span>
                    </div>

                    <!-- Кто собственник -->
                    <div>
                        <%= select_tag :person, grouped_options_for_select(@people_data), multiple: true, class: "js-example-basic-multiple px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
                    </div>

                    <!-- Кнопка применения фильтров -->
                    <button class="px-4 py-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 text-sm font-medium dark:text-black">
                        Применить
                    </button>
                </div>
                <% end %>

                <!-- Кнопка создания -->
                <%= link_to new_plot_path, class: "px-6 py-3 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 font-medium flex items-center gap-2 dark:text-black" do %>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    Новый участок
                <% end %>
            </div>
        </div>
    </div>

    <!-- Сетка участков -->
    <div class="mx-auto max-w-screen-xl px-4 w-full flex-grow">
        <div class="grid w-full sm:grid-cols-2 xl:grid-cols-4 gap-6">
            <%= render partial: "plot_card", collection: @plots, as: :plot %>
        </div>
    </div>

    <!-- Пагинация -->
    <div class="flex-none flex justify-center items-center mt-8">
        <%== @pagy.series_nav %>
    </div>
</div>

<script>
$(document).ready(function() {
    $('.js-example-basic-multiple').select2({
        width: "100%",
        placeholder: "Выберите собственников",
        allowClear: true
    });
});
</script>
