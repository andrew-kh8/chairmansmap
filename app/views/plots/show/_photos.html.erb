<div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-semibold text-gray-900">Фотографии</h2>
    <%= button_tag "Добавить фото", type: "button", class: "text-indigo-500 hover:text-indigo-600 text-sm font-medium dark:text-black" %>
</div>
<div class="grid grid-cols-2 gap-4">
    <% plot.photos.each do |photo| %>
    <div class="aspect-square bg-gray-100 rounded-lg flex items-center justify-center">
        <%= image_tag("https://picsum.photos/400/400") %>
    </div>
    <% end %>
</div>
