<div class="flex items-center justify-around space-x-3">
    <%= image_tag(weather.icon_uri) %>

    <div class="flex flex-col items-center">
        <span class="text-indigo-600 text-2xl dark:text-white"><%= weather.temperature.temp %>°C</span>
        <span class="dark:text-white"><%= weather.description.capitalize %></span>
    </div>

    <div class="flex flex-col items-center">
        <span class="dark:text-white"><%= weather.wind.speed %> м/с</span>
        <span class="dark:text-white"><%= weather.wind.direction %></span>
    </div>

    <div class="flex flex-col items-end">
        <span class="dark:text-white"><%= weather.pressure %> гПа</span>
        <span class="dark:text-white"><%= weather.humidity %> %</span>
    </div>
</div>
