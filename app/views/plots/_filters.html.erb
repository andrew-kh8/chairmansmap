<%= form_with url: plots_path, method: :get do |form| %>
    <div class="flex flex-col sm:flex-row gap-4 flex-wrap">
        <!-- Площадь -->
        <div class="flex items-center gap-2 text-gray-600 dark:text-black">
            <span class="text-sm text-inherit">Площадь:</span>
            <%= form.number_field :area_min, min: 0, step: 0.1, placeholder: "От", value: params[:area_min], class: "w-20 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 dark:bg-zinc-200" %>
            <span class="text-inherit">-</span>
            <%= form.number_field :area_max, min: 0, step: 0.1, placeholder: "До", value: params[:area_max], class: "w-20 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 dark:bg-zinc-200" %>
            <span class="text-sm text-inherit">сот.</span>
        </div>

        <!-- Кто собственник -->
        <div class="min-w-52 max-w-52">
            <%= select_tag :people, grouped_options_for_select(PlotSearch.people_select_options, params[:people]), multiple: true, class: "w-full", placeholder: "Выберите собственников", data: {controller: "tom-select"} %>
        </div>

        <!-- Кнопка применения фильтров -->
        <button class="px-4 py-2 bg-indigo-500 text-white rounded-lg hover:bg-indigo-600 transition duration-200 text-sm font-medium dark:text-black">
            Применить
        </button>
    </div>
<% end %>
