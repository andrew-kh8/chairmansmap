<div class="max-h-full py-8">
    <div class="max-w-6xl mx-auto px-6">

        <%= form_with model: plot, class: "card p-8", data: {controller: "cadastral-number"} do |f| %>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="space-y-6">
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <%= f.label :cadastral_number, "Кадастровый номер", class: "block text-sm font-medium text-gray-700 dark:text-black" %>
                        <%= button_tag "Проверить", type: "button", data: {action: "click->cadastral-number#check", check_type: "plots"}, class: "px-4 py-2 btn-primary rounded-lg transition duration-200 text-sm font-medium" %>
                    </div>
                    <%= f.text_field :cadastral_number,
                          data: {cadastral_number_target: "input"},
                          class: "text-input w-full px-4 py-3 transition duration-200",
                          placeholder: "77:01:0001001:123" %>
                    <div data-cadastral-number-target="result"></div>
                </div>

                <div>
                    <%= f.label :number, "Номер участка", class: "block text-sm font-medium text-default-color mb-2" %>
                    <%= f.text_field :number,
                          class: "text-input w-full px-4 py-3 transition duration-200",
                          placeholder: "123" %>
                </div>

                <div>
                    <%= f.label :person_id, "Владелец", class: "block text-sm font-medium text-default-color mb-2" %>
                    <%= f.select :person_id,
                          options_for_select(people),
                          {},
                          prompt: "Выберите владельца",
                          class: "text-input w-full px-4 py-3 transition duration-200" %>
                </div>

                <div>
                    <%= f.label :owner_type, "Тип владения", class: "block text-sm font-medium text-default-color mb-2" %>
                    <%= f.select :owner_type,
                          options_for_select(Plot.owner_types.to_a),
                          {},
                          class: "text-input w-full px-4 py-3 transition duration-200" %>
                </div>

                <div>
                    <%= f.label :sale_status, "Статус продажи", class: "block text-sm font-medium text-default-color mb-2" %>
                    <%= f.select :sale_status,
                          options_for_select(Plot.sale_statuses.to_a),
                          {},
                          class: "text-input w-full px-4 py-3 transition duration-200" %>
                </div>
            </div>

            <div class="space-y-6">
                <div>
                    <%= f.label :village_id, "Поселок", class: "block text-sm font-medium text-default-color mb-2" %>
                    <%= f.select :village_id,
                          options_for_select(Village.all.map { |village| [village.name, village.id] }),
                          {},
                          class: "text-input w-full px-4 py-3 transition duration-200" %>
                </div>

                <div class="h-48">
                    <%= f.label :description, "Описание", class: "block text-sm font-medium text-default-color mb-2" %>
                    <%= f.text_area :description, rows: 2,
                          class: "text-input w-full h-40 px-4 py-3 transition duration-200 resize-none",
                          placeholder: "Дополнительная информация об участке..." %>
                </div>

                <div class="h-48">
                    <%= f.label :photos, "Фотографии участка", class: "block text-sm font-medium text-gray-700 mb-2 dark:text-black" %>
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center h-40 flex flex-col justify-center dark:border-gray-700">
                        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <p class="mt-2 text-sm text-default-color">Перетащите фото или кликните для загрузки</p>
                        <%= f.file_field :photos, multiple: true, class: "hidden" %>
                        <%= button_tag "Выбрать файлы", type: "button", class: "mt-3 px-4 py-2 btn-primary rounded-lg transition duration-200 text-sm font-medium" %>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex justify-end space-x-4 pt-4 border-t border-gray-200">
            <%= link_to "Отмена", plots_path,
                  class: "px-6 py-3 border border-gray-300 text-default-color rounded-lg hover:bg-gray-50 transition duration-200 font-medium" %>
            <%= f.submit "Создать участок",
                  disabled: true,
                  data: {cadastral_number_target: "submit"},
                  class: "px-6 py-3 btn-primary rounded-lg transition duration-200 font-medium" %>
        </div>
        <% end %>
    </div>
</div>
